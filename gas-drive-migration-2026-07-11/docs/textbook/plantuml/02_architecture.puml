@startuml 02_architecture
skinparam defaultFontName "Noto Sans CJK JP"
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundCorner 8
title 移行スクリプトの全体アーキテクチャ（スプレッドシート UI 版）

actor "移行元ユーザー\n(@google.com)" as user

package "Google スプレッドシート（唯一の操作画面）" {
  rectangle "メニュー\n「📁 ドライブ移行」" as menu
  rectangle "「設定」シート\n移行元/移行先ID・各設定" as settings
  rectangle "「進捗」/「失敗一覧」\nシート" as statusSheet
}

package "Google Apps Script（スプレッドシートに紐づく / 移行元権限で実行）" {
  component "main.js\n(移行スクリプト)" as gas
  database "スクリプト\nプロパティ\n(進捗状態の保存先)" as props
  component "時間主導\nトリガー" as trigger
}

cloud "Drive API v3\n(高度なサービス)" as api

folder "マイドライブ\n移行元フォルダ" as my
database "共有ドライブ\n(@misugi-corp.co.jp)" as sd

user --> settings : ① ID と設定を入力
user --> menu : ② メニューから操作\n(開始/再開/中止/進捗)
menu --> gas : 関数を実行
gas --> settings : 設定を読み込む
gas --> statusSheet : 進捗・失敗を書き出す
gas --> api : files.list / create / update
api --> my : 一覧取得 / removeParents
api --> sd : フォルダ作成 / addParents
gas --> props : 進捗を保存 (中断・再開に備える)
gas --> trigger : 時間切れ前に再開を予約
trigger --> gas : resumeMigration で自動再開

note right of sd
  事前準備として移行元ユーザーを
  「コンテンツ管理者」以上の
  メンバーとして追加しておく
end note
@enduml
