@startuml 04_sequence_migration
skinparam defaultFontName "Noto Sans CJK JP"
skinparam backgroundColor #FFFFFF
skinparam shadowing false
title 移行処理のシーケンス — スプレッドシート操作から自動中断・再開まで

actor "移行元ユーザー" as user
participant "設定シート" as sheet
participant "メニュー\nstartMigration()" as start
participant "runLoop()" as run
participant "進捗シート" as prog
participant "スクリプト\nプロパティ" as props
participant "Drive API v3" as api
participant "時間主導トリガー" as trg

user -> sheet : 移行元/移行先ID・各設定を入力
user -> start : メニュー「② 移行を開始」
start -> sheet : 設定を読み込み・検証
start -> user : 確認ダイアログ（本実行なら警告）
start -> api : 移行元/移行先を検証\n(移行先が共有ドライブ内かチェック)
start -> props : 初期状態を保存 (キュー = [ルート])
start -> run : ループ開始

loop キューが空になるまで (フォルダ1つずつ)
  run -> api : files.list（ファイル一覧）
  run -> api : files.update\naddParents/removeParents = 移動
  run -> api : files.list + create（サブフォルダ find-or-create）
  run -> props : 進捗を保存
  run -> prog : 進捗を書き出し（約10秒間隔）
end

alt 制限時間 (約4.5分) を超過
  run -> props : 状態を保存 (SUSPENDED)
  run -> trg : 60秒後の再開を予約
  trg -> run : resumeMigration()\nキューの続きから自動再開
else キューが空 = 完了
  run -> prog : 状態を DONE で書き出し
  run -> user : 完了トースト / メール通知（設定時）
end
@enduml
