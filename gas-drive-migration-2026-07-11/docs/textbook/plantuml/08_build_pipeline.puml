@startuml 08_build_pipeline
skinparam defaultFontName "Noto Sans CJK JP"
skinparam backgroundColor #FFFFFF
skinparam shadowing false
left to right direction
title 開発フロー — TypeScript からスプレッドシート紐づきスクリプトへ

file "src/main.ts\n(TypeScript)" as ts
file "src/appsscript.json\n(マニフェスト)" as manifest
component "tsc\n(型チェック + 変換)" as tsc
file "dist/main.js\n(GAS 用 JavaScript)" as js
file "dist/appsscript.json" as manifest2
cloud "スプレッドシートに紐づく\nApps Script プロジェクト\n(拡張機能 → Apps Script)" as gasproj

ts --> tsc : mise run build
manifest --> manifest2 : コピー
tsc --> js
js --> gasproj : 方法A: エディタへ貼り付け\n方法B: mise run clasp:push
manifest2 --> gasproj

note bottom of gasproj
  スプレッドシートの「拡張機能 → Apps Script」で開く
  container-bound スクリプト。onOpen でメニューが追加され、
  以後は利用者がスプレッドシートだけで操作できる。
end note
@enduml
